# ===========================================
# IsoSmart Titanium - Variables de Entorno
# ===========================================
# Copia este archivo como .env y configura tus valores

# -------------------------------------------
# API KEYS
# -------------------------------------------
# Gemini API Key (opcional, para asistente IA)
# Obtén tu key en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Fal.ai API Key (Para generación de renders e imágenes fotorrealistas)
# Obtén tu key en: https://fal.ai/
FAL_KEY=tu_fal_key_aqui

# Luma AI API Key (Para generación de videos cinematográficos - Dream Machine)
# Obtén tu key en: https://lumalabs.ai/dream-machine/api
LUMA_API_KEY=tu_luma_api_key_aqui

# Resend API Key (Para envío automático de cotizaciones PDF por email)
# Obtén tu key gratuita en: https://resend.com/
RESEND_API_KEY=tu_resend_api_key_aqui

# Clave de administrador (Para proteger el panel de CRM/Leads)
ADMIN_PASSWORD=admin123

# -------------------------------------------
# CONFIGURACIÓN DE PRECIOS (RD$)
# -------------------------------------------
# Precios unitarios por defecto
PRECIO_PANEL_MURO=925.00
PRECIO_PANEL_TECHO=1125.00
PRECIO_HORMIGON_3000=7350.00
PRECIO_HORMIGON_3500=7950.00
PRECIO_VIGA_H=105.00
PRECIO_ACERO_VARILLA=85.00

# -------------------------------------------
# CONFIGURACIÓN DE EMPRESA
# -------------------------------------------
NOMBRE_EMPRESA=Tu Empresa
TELEFONO_EMPRESA=809-000-0000
EMAIL_EMPRESA=info@tuempresa.com

# -------------------------------------------
# MONEDA Y FORMATO
# -------------------------------------------
MONEDA=RD$
IDIOMA=es

# -------------------------------------------
# STREAMLIT (opcional)
# -------------------------------------------
# Puerto del servidor (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Modo headless (default: true)
STREAMLIT_SERVER_HEADLESS=true
